# Copy this to .env for local development — NEVER commit .env

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Telegram
TELEGRAM_BOT_TOKEN=123456789:ABC...
TELEGRAM_OWNER_CHAT_ID=           # Your personal Telegram chat ID (get via @userinfobot)
TELEGRAM_WEBHOOK_SECRET=          # Random string for webhook validation

# Image Search + News Research (get free key at serper.dev)
SERPER_API_KEY=...

# v2 Research APIs
EXA_API_KEY=...        # exa.ai — semantic search (1k free searches/month)
TAVILY_API_KEY=...     # tavily.com — deep content extraction (1k free searches/month)

# CORS — frontend origins allowed to call this API (comma-separated)
# Local dev:  http://localhost:5173
# Production: https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5173

# GCP
GCP_PROJECT_ID=your-gcp-project-id
REDIS_HOST=127.0.0.1               # Cloud Memorystore IP in production
REDIS_PORT=6379

# Canva
CANVA_TEMPLATE_ID=DAHDs0ivk0M

# Gmail (paths to local OAuth files — only for local dev)
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.pickle
